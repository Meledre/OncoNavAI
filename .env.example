# Backend
RATE_LIMIT_PER_MINUTE=60
DEMO_TOKEN=demo-token
LOCAL_CORE_BASE_URL=http://localhost:8000
# Runtime profile:
# - compat: backward-compatible local/dev behavior (default)
# - strict_full: fail-closed production profile (requires live LLM+RAG backends)
ONCOAI_RELEASE_PROFILE=compat
# Reasoning mode:
# - llm_rag_only: strict LLM+RAG only path (no heuristic/fallback reasoning)
# - compat: legacy compatible behavior
ONCOAI_REASONING_MODE=llm_rag_only
# Case import data-mode policy (DEID/FULL)
# FULL should stay disabled outside private secured installs.
CASE_IMPORT_ALLOW_FULL_MODE=false
CASE_IMPORT_FULL_REQUIRE_ACK=true
CASE_IMPORT_DEID_REDACT_PII=true
# Release feature flags (v1.2 staged rollout)
ONCOAI_DOCTOR_SCHEMA_V1_2_ENABLED=true
ONCOAI_STRUCTURAL_CHUNKER_ENABLED=true
ONCOAI_GUIDELINE_SYNC_ENABLED=true
ONCOAI_CASEFACTS_ENABLED=true
ONCOAI_DRUG_SAFETY_ENABLED=true
ONCOAI_PROMPT_REGISTRY_DIR=/app/docs/prompts
ONCOAI_PROMPT_SCHEMA_STRICT=false
ONCOAI_COMPAT_V1_1_PROJECTION_ENABLED=true
DRUG_SAFETY_CACHE_TTL_HOURS=336
DRUG_SAFETY_REQUEST_TIMEOUT_SEC=12
DRUG_SAFETY_OPENFDA_BASE_URL=https://api.fda.gov
# Frontend one-release compatibility for doctor_report schema_version=1.0.
# Set false after full cutover to v1.2-only clients.
NEXT_PUBLIC_ONCOAI_DOCTOR_REPORT_1_0_COMPAT_ENABLED=true

# Primary provider (OpenAI-compatible)
# For OpenAI use:
# LLM_PRIMARY_URL=https://api.openai.com
# LLM_PRIMARY_MODEL=gpt-4o-mini
# LLM_PRIMARY_API_KEY=sk-...
LLM_PRIMARY_URL=https://api.openai.com
LLM_PRIMARY_MODEL=gpt-4o-mini
LLM_PRIMARY_API_KEY=

# Fallback provider (OpenAI-compatible)
# Option A: local Ollama (recommended for laptop tests)
# If backend runs in Docker, use host.docker.internal:
# LLM_FALLBACK_URL=http://host.docker.internal:11434
# LLM_FALLBACK_MODEL=qwen2.5:3b
# Option B: local vLLM in compose profile full:
# LLM_FALLBACK_URL=http://vllm:8001
# LLM_FALLBACK_MODEL=Qwen/Qwen2.5-7B-Instruct
LLM_FALLBACK_URL=
LLM_FALLBACK_MODEL=qwen2.5:3b
LLM_FALLBACK_API_KEY=
# Optional local rescue model for Ollama when primary fallback model is too slow.
# If qwen2.5:3b times out on CPU, router retries with this lighter model.
LLM_FALLBACK_RESCUE_MODEL=qwen2.5:0.5b
# Optional per-request timeout for fallback provider in seconds.
# Keep >=120 for local CPU models on real-case runs.
# LLM_FALLBACK_TIMEOUT_SEC=180
# LLM structured generation for doctor/patient reports.
# Required for llm_rag_only and strict_full.
LLM_GENERATION_ENABLED=true
# Optional: online probe of provider availability on each /analyze request.
# Keep disabled for lower latency in local/CI.
LLM_PROBE_ENABLED=false

# Retrieval/rerank backends
# VECTOR_BACKEND: local | qdrant
# RERANKER_BACKEND: lexical | llm
# strict_full requires VECTOR_BACKEND=qdrant and RERANKER_BACKEND=llm.
VECTOR_BACKEND=qdrant
QDRANT_URL=
QDRANT_COLLECTION=oncoai_chunks
RETRIEVAL_TOP_K=12
RERANK_TOP_N=6
RERANKER_BACKEND=llm

# Embeddings backend
# EMBEDDING_BACKEND: hash | openai
# strict_full requires EMBEDDING_BACKEND=openai and configured URL/model/key.
# For OpenAI-compatible embeddings endpoint:
# EMBEDDING_URL=https://api.openai.com
# EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_API_KEY=sk-...
EMBEDDING_BACKEND=openai
EMBEDDING_URL=
EMBEDDING_MODEL=
EMBEDDING_API_KEY=

# Frontend BFF
BACKEND_URL=http://backend:8000
# Session/role cookie HMAC secret for BFF auth/session hardening.
# Set a long random value in non-local environments.
ROLE_COOKIE_SECRET=local-role-secret
# Session auth mode: demo | credentials | idp
SESSION_AUTH_MODE=demo
# Login UI override: off | all (all shows CREDENTIALS + DEMO tabs in UI only)
SESSION_AUTH_UI_OVERRIDE=off
# Credentials mode users JSON (empty by default):
# SESSION_USERS_JSON=[{"user_id":"clinician-1","username":"clinician","password":"sha256:<hex>","role":"clinician","active":true}]
SESSION_USERS_JSON=
# IdP bridge mode options
SESSION_IDP_ISSUER=
SESSION_IDP_AUDIENCE=
SESSION_IDP_JWKS_URL=
SESSION_IDP_JWKS_JSON=
SESSION_IDP_HS256_SECRET=
SESSION_IDP_ROLE_CLAIM=role
SESSION_IDP_USER_ID_CLAIM=sub
# Regex policy for accepted IdP user-id claim value.
SESSION_IDP_USER_ID_REGEX=^[A-Za-z0-9._:@-]{1,120}$
SESSION_IDP_ALLOWED_ALGS=RS256,HS256
SESSION_IDP_ALLOWED_ROLES=admin,clinician,patient
SESSION_IDP_CLOCK_SKEW_SEC=60
SESSION_IDP_REQUIRE_JTI=true
SESSION_IDP_REQUIRE_NBF=false
SESSION_IDP_REPLAY_CHECK_ENABLED=true
# Login endpoint brute-force guard (set 0 to disable).
SESSION_LOGIN_RATE_LIMIT_PER_MINUTE=60
SESSION_LOGIN_RATE_LIMIT_WINDOW_SEC=60
# Login rate-limit key mode: global | ip.
# Use `ip` only when deployed behind trusted proxy and `SESSION_TRUST_PROXY_HEADERS=true`.
SESSION_LOGIN_RATE_LIMIT_KEY_MODE=global
# Trust `x-forwarded-for` / `x-real-ip` from proxy for login rate-limit keying.
SESSION_TRUST_PROXY_HEADERS=false
# CSRF guard for mutating session routes (/api/session/login|logout|revoke).
SESSION_CSRF_ENFORCED=true
# Additional trusted origins (comma-separated), optional.
SESSION_CSRF_TRUSTED_ORIGINS=
# Allow requests without browser context headers (Origin/Referer/Sec-Fetch-Site).
# Keep true for CLI/smoke tooling; set false in strict browser-only deployments.
SESSION_CSRF_ALLOW_UNKNOWN_CONTEXT=true
SESSION_AUDIT_MAX_EVENTS=500
SESSION_AUDIT_RETENTION_DAYS=90
# Session incident alert policy (used by /session/audit/summary and Admin Auth Risk Snapshot)
SESSION_AUDIT_ALERT_MIN_EVENTS=10
SESSION_AUDIT_ALERT_DENY_RATE_WARN=0.35
SESSION_AUDIT_ALERT_DENY_RATE_CRITICAL=0.60
SESSION_AUDIT_ALERT_ERROR_COUNT_WARN=5
SESSION_AUDIT_ALERT_ERROR_COUNT_CRITICAL=20
SESSION_AUDIT_ALERT_REPLAY_COUNT_WARN=1
SESSION_AUDIT_ALERT_REPLAY_COUNT_CRITICAL=3
SESSION_AUDIT_ALERT_CONFIG_ERROR_COUNT_WARN=1
SESSION_AUDIT_ALERT_CONFIG_ERROR_COUNT_CRITICAL=3
# Signed session TTLs (seconds): access token + refresh token.
SESSION_ACCESS_TTL_SEC=900
SESSION_REFRESH_TTL_SEC=604800

# Docker build mode:
# - online: install deps from internet (default)
# - offline: install only from local vendor cache (backend/vendor/wheels, frontend/vendor/npm-cache)
PIP_INSTALL_MODE=online
NPM_INSTALL_MODE=online

# Onco CLI quality-gate tuning (local/CI)
ONCOAI_METRICS_WARMUP_CASES=3
# Default release-readiness caseset (fast strict gate).
# Override with a larger set (e.g. cases_v1_release_gate.json / cases_v1_all.json) for extended bake-off.
ONCOAI_CASES_FILE=data/synthetic_cases/cases_v1_strict_release_3.json
ONCOAI_PREFLIGHT_METRICS_P95_GATE=120000
ONCOAI_MIN_RECALL_GATE=0.90
ONCOAI_MIN_PRECISION_GATE=0.80
ONCOAI_MIN_F1_GATE=0.85
ONCOAI_MIN_EVIDENCE_VALID_GATE=0.95
ONCOAI_MIN_IMPORT_DATA_MODE_COVERAGE_GATE=1.0
ONCOAI_MAX_SANITY_FAIL_RATE_GATE=0.0
ONCOAI_MIN_THROUGHPUT_CASES_PER_HOUR_GATE=20
ONCOAI_MIN_TOP3_ACCEPTANCE_RATE_GATE=0.90
ONCOAI_MIN_SUS_SCORE_GATE=80
ONCOAI_MAX_REWRITE_REQUIRED_RATE_GATE=0.0
ONCOAI_MIN_APPROVED_RATIO_GATE=1.0
ONCOAI_MIN_APPROVED_PAIRS_BY_NOSOLOGY_GATE=gastric:5,lung:5,breast:5,colorectal:5,prostate:5,rcc:5,bladder:5,brain_primary_c71:5,cns_metastases_c79_3:5
ONCOAI_MIN_CITATION_COVERAGE_GATE=0.9
ONCOAI_MIN_KEY_FACT_RETENTION_GATE=1.0
ONCOAI_TOP3_SCORECARD_FILE=reports/review/top3_acceptance_scorecard.json
ONCOAI_SUS_INPUT_FILE=reports/review/sus_scorecard.json
ONCOAI_SESSION_INCIDENT_WINDOW_HOURS=24
ONCOAI_SESSION_INCIDENT_FAIL_ON=high
ONCOAI_SESSION_INCIDENT_MAX_CRITICAL_ALERTS=-1
ONCOAI_SESSION_INCIDENT_MAX_WARN_ALERTS=-1
