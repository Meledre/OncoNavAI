cmd_health() {
  prepare_env
  local py
  py="$(python_cmd)"
  ONCO_HEALTH_URL="$(backend_url)/health" "$py" - <<'PY'
import os
import sys
import urllib.request

url = os.environ.get("ONCO_HEALTH_URL", "")
if not url:
    print("error: ONCO_HEALTH_URL is empty", file=sys.stderr)
    raise SystemExit(1)

try:
    with urllib.request.urlopen(url, timeout=10) as response:
        print(response.read().decode("utf-8"))
except Exception as exc:  # noqa: BLE001
    print(f"error: health request failed: {exc}", file=sys.stderr)
    raise SystemExit(1)
PY
}

wait_backend_health() {
  prepare_env
  local py
  py="$(python_cmd)"
  local max_attempts="${1:-30}"
  local sleep_sec="${2:-1}"
  local attempt
  for ((attempt=1; attempt<=max_attempts; attempt+=1)); do
    if ONCO_HEALTH_URL="$(backend_url)/health" "$py" - <<'PY'
import os
import sys
import urllib.request

url = os.environ.get("ONCO_HEALTH_URL", "").strip()
if not url:
    raise SystemExit(1)

try:
    with urllib.request.urlopen(url, timeout=5) as response:
        if response.status == 200:
            raise SystemExit(0)
except Exception:
    pass
raise SystemExit(1)
PY
    then
      return 0
    fi
    sleep "$sleep_sec"
  done
  return 1
}

ensure_backend_ready_for_runtime() {
  local command_name="${1:-command}"
  if wait_backend_health 1 0; then
    return 0
  fi
  die "$command_name requires backend at $(backend_url)/health (run './onco up' after Docker is healthy)"
}

check_backend_vector_preflight() {
  prepare_env
  local py
  py="$(python_cmd)"
  ONCO_HEALTH_URL="$(backend_url)/health" "$py" - <<'PY'
import json
import os
import sys
import urllib.request

url = os.environ.get("ONCO_HEALTH_URL", "").strip()
if not url:
    print("error: ONCO_HEALTH_URL is empty", file=sys.stderr)
    raise SystemExit(1)

try:
    with urllib.request.urlopen(url, timeout=10) as response:
        payload = json.loads(response.read().decode("utf-8"))
except Exception as exc:  # noqa: BLE001
    print(f"error: health request failed: {exc}", file=sys.stderr)
    raise SystemExit(1)

preflight = payload.get("vector_preflight")
if not isinstance(preflight, dict):
    raise SystemExit(0)

backend = str(preflight.get("backend") or "").strip().lower()
status = str(preflight.get("status") or "").strip().lower()
if backend != "qdrant":
    raise SystemExit(0)
if status == "ok":
    raise SystemExit(0)

print(
    "error: qdrant vector preflight failed "
    f"(status={status or 'unknown'}, expected={preflight.get('expected_vector_size')}, actual={preflight.get('actual_vector_size')})",
    file=sys.stderr,
)
raise SystemExit(1)
PY
}

wait_ollama_health() {
  local py
  py="$(python_cmd)"
  local max_attempts="${1:-60}"
  local sleep_sec="${2:-2}"
  local probe_url="${ONCOAI_DEMO_OLLAMA_HEALTH_URL:-http://localhost:11434/api/tags}"
  local attempt
  for ((attempt=1; attempt<=max_attempts; attempt+=1)); do
    if ONCO_OLLAMA_HEALTH_URL="$probe_url" "$py" - <<'PY'
import os
import urllib.request

url = os.environ.get("ONCO_OLLAMA_HEALTH_URL", "").strip()
if not url:
    raise SystemExit(1)

try:
    request = urllib.request.Request(url, method="GET")
    with urllib.request.urlopen(request, timeout=5) as response:
        if 200 <= response.status < 500:
            raise SystemExit(0)
except Exception:
    pass
raise SystemExit(1)
PY
    then
      return 0
    fi
    # Some local setups restrict host->container access for Ollama HTTP even
    # when the container itself is healthy; keep demo smoke resilient.
    if compose exec -T ollama ollama list >/dev/null 2>&1; then
      return 0
    fi
    sleep "$sleep_sec"
  done
  return 1
}

ensure_ollama_model() {
  local model="$1"
  [ -n "$model" ] || die "Ollama demo requires non-empty LLM_FALLBACK_MODEL"
  local auto_pull="${ONCOAI_DEMO_OLLAMA_AUTO_PULL:-true}"
  local list_output
  list_output="$(compose exec -T ollama ollama list 2>/dev/null || true)"
  if printf "%s\n" "$list_output" | awk 'NR>1 {print $1}' | grep -Fxq "$model"; then
    return 0
  fi
  if ! is_truthy "$auto_pull"; then
    die "Ollama model '$model' not found. Pre-pull it or set ONCOAI_DEMO_OLLAMA_AUTO_PULL=true."
  fi
  echo "info: pulling Ollama model '$model' for demo-local-smoke"
  compose exec -T ollama ollama pull "$model"
}

