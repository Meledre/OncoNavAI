    fi
    if [ -z "$fallback_model" ]; then
      fallback_model="qwen2.5:0.5b"
      export LLM_FALLBACK_MODEL="$fallback_model"
    fi
  fi
  if is_truthy "${ONCOAI_DEMO_LOCAL_WITH_VLLM:-false}"; then
    with_vllm="true"
    with_ollama="false"
  elif [ "$require_llm" = "true" ] && { [ -z "$fallback_url" ] || [ "$fallback_url" = "http://vllm:8001" ]; }; then
    with_vllm="true"
  elif [ "$require_llm" = "true" ] && [ "${fallback_url#http://ollama}" != "$fallback_url" ]; then
    with_ollama="true"
