  # shellcheck disable=SC1090
  . "$file_path"
  set +a
}

is_truthy() {
  case "$(echo "${1:-}" | tr '[:upper:]' '[:lower:]')" in
    1|true|yes|on) return 0 ;;
    *) return 1 ;;
  esac
}

first_non_empty() {
  local value
  for value in "$@"; do
    if [ -n "${value:-}" ]; then
      echo "$value"
      return 0
    fi
  done
  echo ""
  return 0
}

apply_demo_profile_stack() {
  local profile="$1"
  local with_vllm="${2:-false}"
  local with_ollama="${3:-false}"
  case "$profile" in
    local)
      if is_truthy "$with_vllm"; then
        compose --profile full up -d --force-recreate backend qdrant vllm
      elif is_truthy "$with_ollama"; then
        compose --profile full up -d --force-recreate backend qdrant ollama
      else
        compose --profile full up -d --force-recreate backend qdrant
      fi
      ;;
    api)
      compose --profile full up -d --force-recreate backend qdrant
      ;;
    *)
      die "unknown demo profile: $profile"
      ;;
  esac
  wait_backend_health 90 2 || die "backend health did not recover after demo profile apply ($profile)"
  wait_ui_health 60 1 || die "frontend did not recover after demo profile apply ($profile)"
}

configure_demo_data_scope() {
  local profile="$1"
  local scope_suffix="${ONCOAI_DEMO_DATA_SCOPE_SUFFIX:-}"
  if [ -z "$scope_suffix" ]; then
    scope_suffix="$(date +%Y%m%d%H%M%S)"
  fi
  scope_suffix="$(echo "$scope_suffix" | tr -c '[:alnum:]_-' '_')"
  local collection_suffix
  collection_suffix="$(echo "${profile}_${scope_suffix}" | tr '[:upper:]' '[:lower:]')"
  local container_data_dir="/app/data/demo_${profile}_smoke_${scope_suffix}"
  export ONCOAI_DATA_DIR="$container_data_dir"
  export ONCOAI_DB_PATH="$container_data_dir/oncoai.sqlite3"
  export QDRANT_COLLECTION="${ONCOAI_DEMO_QDRANT_COLLECTION:-oncoai_demo_${collection_suffix}}"
}

python_cmd() {
  if command -v python3 >/dev/null 2>&1; then
    echo "python3"
    return
  fi
  if command -v python >/dev/null 2>&1; then
    echo "python"
    return
  fi
  die "python3/python not found"
}

python_cmd_with_module() {
  local module="$1"
  if command -v python3 >/dev/null 2>&1 && python3 -c "import $module" >/dev/null 2>&1; then
    echo "python3"
    return
  fi
  if command -v python >/dev/null 2>&1 && python -c "import $module" >/dev/null 2>&1; then
    echo "python"
    return
  fi
  die "python interpreter with module '$module' not found"
}

ensure_env() {
  if [ -f "$ENV_FILE" ]; then
    return
  fi
  [ -f "$ENV_EXAMPLE" ] || die ".env.example not found"
  cp "$ENV_EXAMPLE" "$ENV_FILE"
  echo "created $ENV_FILE from .env.example"
}

compose() {
  require_cmd docker
  docker compose -f "$COMPOSE_FILE" --env-file "$ENV_FILE" "$@"
}

cmd_init() {
  ensure_env
  echo "env ready: $ENV_FILE"
}

cmd_up() {
  prepare_env
  local full_profile="false"
  for arg in "$@"; do
    case "$arg" in
      --full) full_profile="true" ;;
      *) die "unknown option for up: $arg" ;;
    esac
  done

  if [ "$full_profile" = "true" ]; then
    compose --profile full up --build -d
  else
    compose up --build -d
  fi
  echo "stack started"
  echo "ui: $(ui_url)"
  echo "backend health: $(backend_url)/health"
}

cmd_bootstrap() {
  cmd_init
  cmd_up "$@"
  cmd_status
}

cmd_down() {
  prepare_env
  # Include optional profile services (e.g., qdrant/vllm) so down truly
  # stops the whole local stack regardless of how it was started.
  compose --profile full down --remove-orphans
}

cmd_restart() {
  prepare_env
  if [ $# -gt 0 ]; then
    compose restart "$@"
  else
    compose restart
  fi
}

cmd_status() {
  prepare_env
  compose ps
}

cmd_logs() {
