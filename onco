    --min-throughput-cases-per-hour "$(min_throughput_cases_per_hour_gate)" \
    --min-top3-acceptance-rate "$(min_top3_acceptance_rate_gate)" \
    --min-sus-score "$(min_sus_score_gate)" \
    --max-rewrite-required-rate "$(max_rewrite_required_rate_gate)" \
    --min-approved-ratio "$(min_approved_ratio_gate)" \
    --min-approved-pairs-by-nosology "$(min_approved_pairs_by_nosology_gate)" \
    --min-import-data-mode-coverage "$(min_import_data_mode_coverage_gate)" \
    --max-sanity-fail-rate "$(max_sanity_fail_rate_gate)" \
    --min-citation-coverage "$(min_citation_coverage_gate)" \
    --min-key-fact-retention "$(min_key_fact_retention_gate)" \
    --min-recall-like-by-nosology "$(min_recall_by_nosology_gate)" \
    --min-citation-coverage-by-nosology "$(min_citation_coverage_by_nosology_gate)"
}

cmd_load() {
  prepare_env
  ensure_backend_ready_for_runtime "load"
  local py
  py="$(python_cmd)"
  "$py" "$ROOT_DIR/scripts/load_smoke.py" \
    --base-url "$(backend_url)" \
    --token "$(demo_token)" \
    --schema-version "$(schema_version)" \
    --parallel 5 \
    --requests 20
}

cmd_test() {
  prepare_env
  local py
  py="$(python_cmd_with_module pytest)"
  PYTHONPATH="$ROOT_DIR" "$py" -m pytest "$ROOT_DIR/backend/tests" -q
}

cmd_frontend_check() {
  prepare_env
  compose run --rm --no-deps --build frontend sh -lc 'npm run lint && npm run build'
}

cmd_security_check() {
  prepare_env
  local py
  py="$(python_cmd)"
  "$py" "$ROOT_DIR/scripts/security_gate.py" \
    --repo-root "$ROOT_DIR" \
    --sbom-out "$ROOT_DIR/reports/security/sbom_manifest.json" \
    --strict
}

cmd_preflight() {
  prepare_env
  local py
  local import_cases
  local preflight_metrics_gate
  local preflight_load_gate
  local preflight_metrics_http_timeout
  local preflight_load_http_timeout
  py="$(python_cmd)"
  import_cases="$(import_cases_file)"
  preflight_metrics_gate="$(preflight_metrics_p95_gate)"
  preflight_load_gate="$(preflight_load_p95_gate)"
  preflight_metrics_http_timeout="$(preflight_metrics_http_timeout_sec)"
  preflight_load_http_timeout="$(preflight_load_http_timeout_sec)"

  cmd_test
  # Backend runs without auto-reload; restart to pick up latest mounted code before runtime smoke.
  cmd_restart backend
  wait_backend_health 30 1 || die "backend health did not recover after restart in preflight"
  check_backend_vector_preflight || die "backend vector preflight failed in preflight"
  wait_ui_health 30 1 || die "frontend did not recover before smoke in preflight"
  (ONCO_SMOKE_HTTP_TIMEOUT_SEC=180 ONCO_SMOKE_CHECK_LOGIN_RATE_LIMIT=true ONCO_SMOKE_LOGIN_RATE_LIMIT_PROBE_ATTEMPTS=120 ONCO_SMOKE_CHECK_SESSION_CSRF=true ONCO_SMOKE_SKIP_REINDEX=true cmd_smoke)
  (ONCOAI_CASE_SMOKE_HTTP_TIMEOUT_SEC=180 ONCO_SMOKE_CHECK_SESSION_CSRF=true ONCO_SMOKE_SKIP_REINDEX=true cmd_case_smoke)
  cmd_incident_check

  "$py" "$ROOT_DIR/scripts/run_metrics.py" \
    --base-url "$(backend_url)" \
    --token "$(demo_token)" \
    --cases "$(cases_file)" \
    --import-cases "$import_cases" \
    --golden-pairs "$(golden_pairs_file)" \
    --report-by-nosology \
    --required-import-profiles "$(required_import_profiles)" \
    --schema-version "$(schema_version)" \
    --out "$(metrics_out)" \
    --warmup-cases "$(metrics_warmup_cases)" \
    --top3-scorecard "$(top3_scorecard_file)" \
    --sus-input "$(sus_input_file)" \
    --http-timeout-sec "$preflight_metrics_http_timeout" \
    --http-retry-attempts 1 \
    --http-retry-delay-ms 0 \
    --max-p95-ms "$preflight_metrics_gate" \
    --min-recall-like "$(min_recall_gate)" \
    --min-throughput-cases-per-hour "$(min_throughput_cases_per_hour_gate)" \
    --min-top3-acceptance-rate "$(min_top3_acceptance_rate_gate)" \
    --min-sus-score "$(min_sus_score_gate)" \
    --max-rewrite-required-rate "$(max_rewrite_required_rate_gate)" \
    --min-approved-ratio "$(min_approved_ratio_gate)" \
    --min-approved-pairs-by-nosology "$(min_approved_pairs_by_nosology_gate)" \
    --min-import-success-ratio "$(min_import_success_gate)" \
    --min-import-profile-coverage "$(min_import_profile_coverage_gate)" \
    --min-import-required-field-coverage "$(min_import_required_field_coverage_gate)" \
    --min-import-data-mode-coverage "$(min_import_data_mode_coverage_gate)" \
    --max-sanity-fail-rate "$(max_sanity_fail_rate_gate)" \
    --min-citation-coverage "$(min_citation_coverage_gate)" \
    --min-recall-like-by-nosology "$(min_recall_by_nosology_gate)" \
    --min-citation-coverage-by-nosology "$(min_citation_coverage_by_nosology_gate)"

  "$py" "$ROOT_DIR/scripts/load_smoke.py" \
    --base-url "$(backend_url)" \
    --token "$(demo_token)" \
    --schema-version "$(schema_version)" \
    --parallel 5 \
    --requests 20 \
    --http-timeout-sec "$preflight_load_http_timeout" \
    --max-p95-ms "$preflight_load_gate" \
    --require-all-ok

  cmd_frontend_check
  cmd_security_check
}

cmd_release_readiness() {
  prepare_env
  local py
  py="$(python_cmd)"
  cmd_preflight
  "$py" "$ROOT_DIR/scripts/release_readiness_check.py" \
    --repo-root "$ROOT_DIR" \
    --require-quality-artifacts \
    --out "$ROOT_DIR/reports/release/readiness_report.json"
}

main() {
  local command="${1:-help}"
  shift || true

  case "$command" in
    bootstrap) cmd_bootstrap "$@" ;;
    init) cmd_init ;;
    up) cmd_up "$@" ;;
    down) cmd_down ;;
    restart) cmd_restart "$@" ;;
    status) cmd_status ;;
    logs) cmd_logs "$@" ;;
    health) cmd_health ;;
    governance) cmd_governance ;;
    smoke) cmd_smoke ;;
    idp-smoke) cmd_idp_smoke "$@" ;;
    case-smoke) cmd_case_smoke ;;
    gastric-smoke) cmd_gastric_smoke ;;
    multi-onco-smoke) cmd_multi_onco_smoke ;;
    pdf-pack-smoke) cmd_pdf_pack_smoke "$@" ;;
    prod-release) cmd_prod_release "$@" ;;
    demo-local-smoke) cmd_demo_local_smoke ;;
    demo-api-smoke) cmd_demo_api_smoke ;;
    incident-check) cmd_incident_check ;;
    security-check) cmd_security_check ;;
    release-readiness) cmd_release_readiness ;;
    metrics) cmd_metrics ;;
    load) cmd_load ;;
    frontend-check) cmd_frontend_check ;;
    preflight) cmd_preflight ;;
    test) cmd_test ;;
    help|-h|--help) print_help ;;
    *) die "unknown command: $command (use './onco help')" ;;
  esac
}

main "$@"
