token = os.environ.get("ONCO_GOV_TOKEN", "")
if not url:
    print("error: ONCO_GOV_URL is empty", file=sys.stderr)
    raise SystemExit(1)

request = urllib.request.Request(
    url,
    method="GET",
    headers={
        "x-role": "admin",
        "x-demo-token": token,
    },
)
try:
    with urllib.request.urlopen(request, timeout=20) as response:
        payload = json.loads(response.read().decode("utf-8"))
except Exception as exc:  # noqa: BLE001
    print(f"error: governance request failed: {exc}", file=sys.stderr)
    raise SystemExit(1)

governance = payload.get("governance") or {}
summary = {
    "kb_version": payload.get("kb_version"),
    "sources_total": governance.get("sources_total", 0),
    "documents_total": governance.get("documents_total", 0),
    "versions_total": governance.get("versions_total", 0),
    "disease_registry_total": governance.get("disease_registry_total", 0),
    "latest_ingestion_runs": governance.get("latest_ingestion_runs", []),
}
print(json.dumps(summary, ensure_ascii=False, indent=2))
PY
}

